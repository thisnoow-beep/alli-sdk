{
  "name": "alli-sdk-playground",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "dev:mock": "vite --mode mock",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,css}\" index.html"
  },
  "dependencies": {
    "@fontsource/eb-garamond": "^5.0.0",
    "@fontsource/jetbrains-mono": "^5.0.0",
    "@fontsource/noto-sans-kr": "^5.0.0",
    "@fontsource/noto-serif-kr": "^5.0.0",
    "@fontsource/saira-condensed": "^5.0.0",
    "dompurify": "^3.2.0",
    "marked": "^15.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
