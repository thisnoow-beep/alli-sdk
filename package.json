{
  "name": "alli-sdk-playground",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "dev:mock": "vite --mode mock",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,css}\" index.html"
  },
  "dependencies": {
    "d2coding": "^1.3.2",
    "dompurify": "^3.2.0",
    "highlight.js": "^11.11.1",
    "marked": "^15.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "jsdom": "^29.1.1",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
